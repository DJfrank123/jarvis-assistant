# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Local LLM Configuration (Optional - for Ollama)
USE_LOCAL_LLM=false
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama2

# Voice Configuration
VOICE_LANGUAGE=en-US
VOICE_ENABLED=true

# Hand Detection
HAND_DETECTION_ENABLED=true
HAND_DETECTION_CONFIDENCE=0.7

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true

# System Commands
ALLOW_SYSTEM_COMMANDS=true
SAFE_MODE=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=jarvis.log
