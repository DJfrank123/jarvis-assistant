{\n  "name": "jarvis-assistant",\n  "version": "1.0.0",\n  "description": "Personal AI Computer Assistant - Like Jarvis from Iron Man",\n  "main": "main.js",\n  "scripts": {\n    "start": "electron .",\n    "dev": "concurrently \"npm run start-backend\" \"npm run start-electron\"",\n    "start-backend": "cd backend && python app.py",\n    "start-electron": "wait-on http://localhost:8000 && electron .",\n    "build": "electron-builder",\n    "build-win": "electron-builder --win",\n    "build-mac": "electron-builder --mac",\n    "build-linux": "electron-builder --linux"\n  },\n  "build": {\n    "appId": "com.jarvis.assistant",\n    "productName": "Jarvis AI Assistant",\n    "directories": {"buildResources": "assets"},\n    "files": ["main.js", "preload.js", "node_modules/**/*", "frontend/**/*"],\n    "win": {"target": ["nsis", "portable"], "icon": "assets/icon.ico"},\n    "nsis": {"oneClick": false, "allowToChangeInstallationDirectory": true, "createDesktopShortcut": true, "createStartMenuShortcut": true, "shortcutName": "Jarvis AI Assistant"},\n    "mac": {"target": ["dmg", "zip"], "icon": "assets/icon.icns", "category": "public.app-category.utilities"},\n    "linux": {"target": ["AppImage", "deb"], "icon": "assets/icon.png", "category": "Utility"}\n  },\n  "dependencies": {"electron-squirrel-startup": "^1.1.1"},\n  "devDependencies": {"electron": "^27.0.0", "electron-builder": "^24.6.4", "concurrently": "^8.2.0", "wait-on": "^7.0.1", "electron-is-dev": "^2.0.0"}\n}\n